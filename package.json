{
  "name": "ad-replica-studio",
  "version": "0.1.1",
  "private": true,
  "description": "A compliant MVP for discovering top-selling products, analyzing ad media, and generating original promotion concepts.",
  "author": "jjkkbr",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "desktop": "electron .",
    "verify:syntax": "node --check src/server.js && node --check public/app.js && node --check desktop/main.cjs && node --check edge-extension/popup.js && node --check scripts/verify-edge-extension.mjs && node --check scripts/verify-ui.mjs",
    "verify:edge": "node scripts/verify-edge-extension.mjs",
    "verify:ui": "node scripts/verify-ui.mjs http://127.0.0.1:4173",
    "verify": "npm run verify:syntax && npm run verify:edge",
    "pack": "electron-builder --config electron-builder.config.cjs --dir",
    "dist": "electron-builder --config electron-builder.config.cjs --win",
    "dist:signed": "set \"CODE_SIGNING_REQUIRED=1\"&& electron-builder --config electron-builder.config.cjs --win"
  },
  "build": {
    "appId": "com.local.adreplicastudio",
    "productName": "爆品广告工作台",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "src/**/*",
      "public/**/*",
      "data/products.sample.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "edge-extension",
        "to": "edge-extension",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "爆品广告工作台"
    }
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2"
  },
  "engines": {
    "node": ">=20"
  }
}
