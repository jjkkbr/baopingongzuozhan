{
  "manifest_version": 3,
  "name": "爆品工作台采集助手",
  "version": "0.1.0",
  "description": "从当前已打开且有权访问的商品页面读取已渲染商品信息，并发送到本地爆品广告工作台。",
  "action": {
    "default_title": "发送商品到爆品工作台",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:4173/*",
    "http://127.0.0.1:4173/*"
  ]
}
